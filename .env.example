# Perplexity (direct fallback if SAP AI Core unavailable)
PPLX_KEY=pplx-your-key-here

# Gmail SMTP
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_DISPLAY_NAME=Scoop

# Supabase (service role key for backend operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_secret_your-service-role-key

# Cron auth (protects /api/digest endpoint)
CRON_SECRET=generate-a-random-string

# App URLs
APP_URL=https://your-github-pages-url
ALLOWED_ORIGINS=https://your-github-pages-url,http://localhost:8080

# ALLOWED_RECIPIENTS safety gate (comma-separated emails, or * for all)
ALLOWED_RECIPIENTS=you@company.com

# SAP AI Core (PRIMARY provider — all model calls route through here)
SAP_AICORE_AUTH_URL=https://your-tenant.authentication.eu10.hana.ondemand.com/oauth/token
SAP_AICORE_CLIENT_ID=your-client-id
SAP_AICORE_CLIENT_SECRET=your-client-secret
SAP_AICORE_BASE_URL=https://api.ai.prod.eu-central-1.aws.ml.hana.ondemand.com
SAP_AICORE_RESOURCE_GROUP=default
AICORE_DEPLOYMENT_PPLX=your-perplexity-deployment-id
AICORE_DEPLOYMENT_GPT4O_MINI=your-gpt4o-mini-deployment-id

# LiteLLM (fallback for dedup if AI Core unavailable)
LITELLM_URL=https://your-litellm-proxy
LITELLM_KEY=your-litellm-key
