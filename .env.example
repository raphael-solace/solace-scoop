# Perplexity API (research queries)
PPLX_KEY=pplx-your-key-here

# Gmail SMTP (digest + welcome emails)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_DISPLAY_NAME=Solace Scoop

# Supabase (database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Cron auth (protects /api/digest endpoint)
CRON_SECRET=a-random-secret-string

# Frontend URL (used in email links)
APP_URL=https://raphael-solace.github.io/solace-scoop

# CORS
ALLOWED_ORIGINS=https://raphael-solace.github.io,http://localhost:8080

# LiteLLM (cheap model for freshness/dedup review — optional)
LITELLM_URL=https://your-litellm-endpoint
LITELLM_KEY=your-litellm-key
